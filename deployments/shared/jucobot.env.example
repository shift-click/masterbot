# ============================================================================
# JucoBot 환경변수 설정
# [REQUIRED] = 배포 시 반드시 설정해야 함
# [OPTIONAL] = 비워두면 기능 비활성 또는 기본값 사용
# ============================================================================

# --- Container ---

# [REQUIRED] Docker Compose 프로젝트 이름
JUCOBOT_COMPOSE_PROJECT_NAME=jucobot-app
# [REQUIRED] JucoBot 컨테이너 이름
JUCOBOT_CONTAINER_NAME=jucobot-app
# [REQUIRED] Docker 네트워크 이름 (Redroid와 공유)
JUCOBOT_STACK_NETWORK=jucobot-stack

# --- Iris Transport ---

# [REQUIRED] Iris 어댑터 활성화 (false로 두면 core-only 검증 모드)
JUCOBOT_IRIS_ENABLED=true
# [REQUIRED when IRIS_ENABLED=true] Iris WebSocket URL
JUCOBOT_IRIS_WS_URL=ws://jucobot-redroid:3000/ws
# [REQUIRED when IRIS_ENABLED=true] Iris HTTP URL
JUCOBOT_IRIS_HTTP_URL=http://jucobot-redroid:3000
# 멀티 인스턴스: config.yaml의 iris.instances[] 배열로 설정 (환경변수 대신 YAML 권장)
# iris:
#   instances:
#     - id: main
#       ws_url: ws://server-a:3000/ws
#       http_url: http://server-a:3000
#     - id: sub
#       ws_url: ws://server-b:3000/ws
#       http_url: http://server-b:3000

# [REQUIRED] 호스트에서 Iris 준비 상태를 확인할 때 쓰는 URL
IRIS_HEALTHCHECK_URL=http://127.0.0.1:3000/dashboard

# --- Bot Core ---

# [OPTIONAL] 로그 레벨 (debug, info, warn, error). 기본값: info
JUCOBOT_BOT_LOG_LEVEL=info
# [OPTIONAL] 비워두면 up-jucobot.sh가 /opt/jucobot/shared/current-release 값을 자동 주입
JUCOBOT_BUILD_VERSION=
# [OPTIONAL] 빌드 git revision
JUCOBOT_BUILD_REVISION=
# [OPTIONAL] 빌드 시각
JUCOBOT_BUILD_TIME=

# --- Admin Metrics & Dashboard ---

# [OPTIONAL] 메트릭 수집 활성화. 기본값: false
JUCOBOT_ADMIN_METRICS_ENABLED=true
# [OPTIONAL] 메트릭 SQLite DB 경로. 기본값: data/admin-metrics.db
JUCOBOT_ADMIN_METRICS_DB_PATH=/app/data/admin-metrics.db
# [REQUIRED when METRICS_ENABLED=true] chat_id/user_id pseudonym용 HMAC 시크릿
JUCOBOT_ADMIN_PSEUDONYM_SECRET=replace-with-long-random-secret
# [OPTIONAL] 관리자 대시보드 활성화. 기본값: false
JUCOBOT_ADMIN_ENABLED=true
# [OPTIONAL] 대시보드 리슨 주소. 기본값: 0.0.0.0:9090
JUCOBOT_ADMIN_LISTEN_ADDR=0.0.0.0:9090
# [OPTIONAL] 대시보드 base path. 기본값: /admin
JUCOBOT_ADMIN_BASE_PATH=/admin
# [OPTIONAL] reverse proxy에서 주입하는 인증 이메일 헤더
JUCOBOT_ADMIN_AUTH_EMAIL_HEADER=X-Auth-Request-Email
# [REQUIRED when ADMIN_ENABLED=true] 대시보드 접근 허용 이메일 (쉼표 구분)
JUCOBOT_ADMIN_ALLOWED_EMAILS=owner@gmail.com,operator@gmail.com
# [OPTIONAL] 대시보드 audience scope (email|role|tenants|rooms|features 형식)
JUCOBOT_ADMIN_AUDIENCE_SCOPES=owner@gmail.com|operator|*|*|*,partner@example.com|partner|tenant-a|room-hash-a|coin;stock,customer@example.com|customer|tenant-a|room-hash-a|coin
# [OPTIONAL] 신뢰할 수 있는 프록시 CIDR
JUCOBOT_ADMIN_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,172.18.0.0/16
# [OPTIONAL] admin command smoke probe가 사용할 chat_id.
# 비워두면 합성 식별자(admin-smoke://synthetic)로 격리되어 운영 방의
# room_id_hash에 가짜 metric을 누적시키지 않는다. 단, ACL 평가에서
# 모든 명령이 deny될 수 있으므로 smoke 결과를 의미 있게 활용하려면
# 별도의 전용 테스트 방을 등록하고 그 chat_id를 명시 설정한다.
JUCOBOT_ADMIN_SMOKE_ROOM_CHAT_ID=

# --- OAuth2 Proxy (관리자 대시보드 외부 노출 시) ---

# [OPTIONAL] 관리자 공개 호스트명. 권장: masterbot-admin.<domain>
JUCOBOT_ADMIN_SERVER_NAME=masterbot-admin.example.com
# [OPTIONAL] 관리자 대시보드 외부 포트
JUCOBOT_ADMIN_PUBLIC_PORT=8080
# [REQUIRED when using admin-auth.yml] Google OAuth2 client ID
OAUTH2_PROXY_CLIENT_ID=replace-with-google-client-id
# [REQUIRED when using admin-auth.yml] Google OAuth2 client secret
OAUTH2_PROXY_CLIENT_SECRET=replace-with-google-client-secret
# [REQUIRED when using admin-auth.yml] 32-byte base64 쿠키 암호화 시크릿
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64-secret
# [OPTIONAL] OAuth2 허용 이메일 (ADMIN_ALLOWED_EMAILS와 동일하게 설정 권장)
OAUTH2_PROXY_ALLOWED_EMAILS=owner@gmail.com,operator@gmail.com

# --- Coupang ---

# [OPTIONAL] 쿠팡 스크래퍼 프록시 URL (한국 IP 필요 시). 비워두면 직접 연결
# 형식: http://user:pass_country-kr@geo.iproyal.com:12321
JUCOBOT_COUPANG_SCRAPER_PROXY_URL=

# --- Inline Alert (JucoBot 프로세스 내 즉시 알림) ---

# [REQUIRED] Telegram Bot API 토큰
JUCOBOT_ALERT_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
# [REQUIRED] Telegram 채팅 ID (알림 수신)
JUCOBOT_ALERT_TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
# [OPTIONAL] Telegram API base URL. 기본값: https://api.telegram.org
JUCOBOT_ALERT_TELEGRAM_API_BASE=https://api.telegram.org
# [OPTIONAL] 알림 앱 이름. 기본값: jucobot
JUCOBOT_ALERT_APP_NAME=jucobot

# --- Alertd (집계형 Telegram 알림 사이드카) ---

# [OPTIONAL] Alertd 사이드카 활성화. 기본값: false
JUCOBOT_ALERTD_ENABLED=true
# [OPTIONAL] Alertd 컨테이너 이름
JUCOBOT_ALERTD_CONTAINER_NAME=jucobot-alertd
# [OPTIONAL] Alertd 앱 이름
ALERTD_APP_NAME=jucobot
# [OPTIONAL] 메트릭 DB 경로 (JucoBot과 동일 DB 공유)
ALERTD_METRICS_DB_PATH=/app/data/admin-metrics.db
# [OPTIONAL] 메트릭 폴링 간격. 기본값: 1m
ALERTD_POLL_INTERVAL=1m
# [OPTIONAL] critical 알림 윈도우. 기본값: 3m
ALERTD_CRITICAL_WINDOW=3m
# [OPTIONAL] warning 알림 윈도우. 기본값: 10m
ALERTD_WARNING_WINDOW=10m
# [OPTIONAL] 에러율 임계값. 기본값: 0.05
ALERTD_ERROR_RATE_THRESHOLD=0.05
# [OPTIONAL] p95 지연 임계값 (ms). 기본값: 1500
ALERTD_P95_THRESHOLD_MS=1500
# [OPTIONAL] 최소 명령 수 (알림 발동 조건). 기본값: 10
ALERTD_MIN_COMMANDS=10
# [OPTIONAL] 중복 알림 억제 윈도우. 기본값: 15m
ALERTD_DEDUP_WINDOW=15m
# [REQUIRED when ALERTD_ENABLED=true] Alertd Telegram Bot 토큰
ALERTD_TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
# [REQUIRED when ALERTD_ENABLED=true] Alertd Telegram 채팅 ID
ALERTD_TELEGRAM_CHAT_ID=replace-with-telegram-chat-id
# [OPTIONAL] Alertd Telegram API base URL. 기본값: https://api.telegram.org
ALERTD_TELEGRAM_API_BASE=https://api.telegram.org
