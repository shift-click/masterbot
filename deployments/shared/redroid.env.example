# ============================================================================
# Redroid 환경변수 설정
# [REQUIRED] = 배포 시 반드시 설정해야 함
# [OPTIONAL] = 비워두면 기본값 사용
# ============================================================================

# [REQUIRED] Docker Compose 프로젝트 이름
REDROID_PROJECT_NAME=jucobot-redroid
# [REQUIRED] Redroid 컨테이너 이름
REDROID_CONTAINER_NAME=jucobot-redroid
# [REQUIRED] 이 호스트가 실제 Redroid 전용 서버일 때만 1로 설정. 기본값 0은 실행 차단.
REDROID_HOST_ENABLED=0
# [OPTIONAL] Redroid Docker 이미지. 기본값: redroid/redroid:12.0.0-latest
REDROID_IMAGE=redroid/redroid:12.0.0-latest
# [OPTIONAL] ADB/Iris 바인딩 주소. 기본값: 127.0.0.1 (외부 접근은 0.0.0.0)
REDROID_BIND_ADDRESS=127.0.0.1
# [OPTIONAL] ADB 포트. 기본값: 5555
REDROID_ADB_PORT=5555
# [OPTIONAL] Iris 포트. 기본값: 3000 (충돌 시 다른 포트로 변경)
REDROID_IRIS_PORT=3000
# [OPTIONAL] GPU 모드. 기본값: guest
REDROID_GPU_MODE=guest
# [OPTIONAL] memfd 사용. 기본값: true
REDROID_USE_MEMFD=true
# [OPTIONAL] 데이터 볼륨 이름 (Android 파일시스템 유지)
REDROID_DATA_VOLUME=jucobot-redroid-data
# [REQUIRED] Docker 네트워크 이름 (JucoBot과 공유)
JUCOBOT_STACK_NETWORK=jucobot-stack
